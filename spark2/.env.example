# DGX Spark #2 — Chat node environment
# Copy to .env and edit before running docker compose up.

# vLLM container tag — check https://build.nvidia.com/spark/vllm for the latest
VLLM_VERSION=26.02-py3

# Absolute path to the cloned model directory on this host
MODEL_PATH=/models/Qwen3-8B

# Maximum sequence length (tokens). Tune based on your use case and available memory.
MAX_MODEL_LEN=8192

# Maximum concurrent in-flight sequences. Lower this if you hit OOM errors.
MAX_NUM_SEQS=256

# Fraction of unified memory vLLM reserves for the KV cache (0.0–1.0).
# If enabling the backup embedding service, lower this to 0.7.
GPU_MEM_UTIL=0.9
