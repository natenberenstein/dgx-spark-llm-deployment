# Gateway environment — copy to .env and fill in real values.
# Do NOT commit .env to version control.

# LiteLLM master key — used to create team keys and access the admin API.
# Generate a strong random value: openssl rand -hex 32
LITELLM_MASTER_KEY=sk-change-this-to-a-secure-key

# LiteLLM container version — check https://github.com/BerriAI/litellm/releases
LITELLM_VERSION=v1.72.0
